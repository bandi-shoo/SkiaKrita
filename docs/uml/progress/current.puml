@startuml SkiaKrita Current Progress

title SkiaKrita -- Current Implementation (PR #4 Undo / Pressure / Keyboard)
skinparam componentStyle rectangle
skinparam packageStyle frame

legend right
  <color:green>~~</color> Implemented
  <color:yellow>~~</color> Minimal / data-only
  <color:gray>~~</color> Planned (stub / empty)
endlegend

package "apps/krita_gui" <<Win32>> {
    [WinMain]      <<entry point>>   #PaleGreen
    [App]          <<controller>>    #PaleGreen
    [Win32Window]  <<HWND wrapper>>  #PaleGreen
    note bottom of [Win32Window]
      WM_PAINT   -> composite -> StretchDIBits
      WM_MOUSE*  -> MouseEvent -> BrushTool
      WM_KEYDOWN -> KeyEvent -> App (Ctrl+Z/Y)
      WM_SIZE    -> resize callback
    end note
}

package "apps/krita_shell" <<Console>> {
    [main.cpp] <<CLI test>> #PaleGreen
}

package "libs/core" <<Pure C++20>> {
    [Version]          #PaleGreen
    [Color]            #PaleGreen
    [Document Model]   #PaleGreen
    [Layer System]     #PaleGreen
    [Brush Engine]     #PaleGreen
    [Command / Undo]   #PaleGreen
    [BrushStrokeCommand] #PaleGreen
    [Selection]        #PaleGreen
    [Color Management] #LightGray

    package "Input / Tool" {
        [MouseEvent]  #PaleGreen
        [KeyEvent]    #PaleGreen
        [Tool]        #PaleGreen
        [BrushTool]   #PaleGreen
    }
}

package "libs/graphics_skia" <<Pure C++20 interface>> {
    [SkiaContext] #PaleGreen
    [Renderer]   #PaleGreen
    note bottom of [Renderer]
      compositeDocument()
      getCompositeBuffer()
      renderBrushStroke() -- pressure-sensitive
      fillLayer()
      saveComposite()
    end note
}

package "External" {
    [Skia (vcpkg)] <<third-party>> #PaleGreen
    [Win32 API]    <<OS>>          #PaleGreen
}

' -- GUI wiring --
[WinMain]      --> [App]            : creates
[App]          --> [Win32Window]    : owns window
[App]          --> [Document Model] : owns document
[App]          --> [BrushTool]      : active tool
[App]          --> [Renderer]       : composite + blit
[App]          --> [Command / Undo] : CommandHistory

' -- Event flow --
[Win32Window]  ..> [MouseEvent]     : translates WM_MOUSE* ->
[Win32Window]  ..> [KeyEvent]       : translates WM_KEYDOWN ->
[App]          --> [Tool]           : dispatches events

' -- Undo pipeline --
[BrushTool]    ..> [BrushStrokeCommand] : creates on release
[BrushStrokeCommand] --|> [Command / Undo] : extends Command
[App]          --> [Command / Undo] : Ctrl+Z / Ctrl+Y

' -- CLI shell --
[main.cpp]     --> [Document Model] : creates document
[main.cpp]     --> [SkiaContext]    : test pattern
[main.cpp]     --> [Renderer]       : stroke + composite

' -- Rendering pipeline --
[BrushTool]    --> [Brush Engine]   : builds strokes
[Renderer]     --> [Document Model] : reads layers
[Renderer]     --> [Skia (vcpkg)]   : raster ops
[SkiaContext]  --> [Skia (vcpkg)]
[Win32Window]  --> [Win32 API]      : StretchDIBits

' -- Core relationships --
[Document Model] --> [Layer System]
[BrushTool]      --|> [Tool]
[Tool]           --> [MouseEvent]

@enduml
