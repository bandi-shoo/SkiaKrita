@startuml SkiaKrita Current Progress

title SkiaKrita – Current Implementation (PR #2 Core Model)
skinparam componentStyle rectangle
skinparam packageStyle frame

legend right
  <color:green>██</color> Implemented
  <color:yellow>██</color> Minimal / data-only
  <color:gray>██</color> Planned (stub / empty)
endlegend

package "apps/krita_shell" {
    [main.cpp] <<Executable>> #PaleGreen
    note bottom of [main.cpp]
      Console bootstrap.
      Creates Document + Layers,
      renders brush stroke via
      Renderer, composites layers,
      saves PNGs.
    end note
}

package "libs/core" <<Pure C++20>> {
    [Version]          #PaleGreen
    [Color]            #PaleGreen
    [Document Model]   #PaleGreen
    [Layer System]     #PaleGreen
    [Brush Engine]     #PaleGreen
    [Command / Undo]   #PaleGreen
    [Selection]        #PaleGreen
    [Color Management] #LightGray
}

package "libs/graphics_skia" <<Pure C++20 interface>> {
    [SkiaContext] #PaleGreen
    note bottom of [SkiaContext]
      createSurface()
      drawTestPattern()
      saveSnapshot()
    end note

    [Renderer]   #PaleGreen
    note bottom of [Renderer]
      compositeDocument()
      renderBrushStroke()
      fillLayer()
      saveComposite()
    end note
}

package "External" {
    [Skia (vcpkg)] <<third-party>> #PaleGreen
}

' ── relationships ──
[main.cpp] --> [Version]        : prints version
[main.cpp] --> [Document Model] : creates document
[main.cpp] --> [Layer System]   : adds layers
[main.cpp] --> [Brush Engine]   : builds stroke
[main.cpp] --> [Command / Undo] : demo
[main.cpp] --> [Selection]      : demo
[main.cpp] --> [SkiaContext]    : test pattern
[main.cpp] --> [Renderer]       : stroke + composite

[Document Model] --> [Layer System]
[Brush Engine]   --> [Color]
[Layer System]   --> [Color]

[Renderer]    --> [Skia (vcpkg)]
[SkiaContext]  --> [Skia (vcpkg)]

@enduml
