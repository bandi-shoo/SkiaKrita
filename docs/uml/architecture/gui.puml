@startuml SkiaKrita GUI Architecture

title SkiaKrita – GUI Architecture
skinparam componentStyle rectangle
skinparam packageStyle frame

legend right
  Pure C++20 = platform-independent (libs/)
  Win32      = platform-specific (apps/)
endlegend

package "apps/krita_gui" <<Win32 platform>> {
    [WinMain]        <<entry point>>
    [App]            <<controller>>
    [Win32Window]    <<HWND + message loop>>

    note bottom of [Win32Window]
      WM_PAINT   → composite → StretchDIBits
      WM_MOUSE*  → MouseEvent → Tool
      WM_SIZE    → resize callback
    end note
}

package "apps/krita_shell" <<Console>> {
    [main.cpp] <<CLI test>>
}

package "libs/core" <<Pure C++20>> {
    [Document Model]
    [Layer System]
    [Brush Engine]
    [Command / Undo]
    [Selection]

    package "Input / Tool" {
        [MouseEvent]  <<value type>>
        [Tool]        <<interface>>
        [BrushTool]   <<concrete>>
    }
}

package "libs/graphics_skia" <<Pure C++20 interface>> {
    [SkiaContext]  <<test patterns>>
    [Renderer]     <<composite + strokes>>

    note bottom of [Renderer]
      compositeDocument()
      getCompositeBuffer()   ← raw pixels for window
      renderBrushStroke()
    end note
}

package "External" {
    [Skia]   <<third-party>>
    [Win32 API] <<OS>>
}

' ── App wiring ──
[WinMain]      --> [App]            : creates
[App]          --> [Win32Window]    : owns window
[App]          --> [Document Model] : owns document
[App]          --> [BrushTool]      : active tool
[App]          --> [Renderer]       : composite + blit

' ── Event flow ──
[Win32Window]  ..> [MouseEvent]     : translates WM_* →
[App]          --> [Tool]           : dispatches events

' ── Rendering pipeline ──
[BrushTool]    --> [Brush Engine]   : builds strokes
[BrushTool]    ..> [Renderer]       : render callback (via App)
[Renderer]     --> [Document Model] : reads layers
[Renderer]     --> [Skia]           : raster ops
[Win32Window]  --> [Win32 API]      : StretchDIBits

' ── Core relationships ──
[Document Model] --> [Layer System]
[BrushTool]      --|> [Tool]
[Tool]           --> [MouseEvent]

@enduml
